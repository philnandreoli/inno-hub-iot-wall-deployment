# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=

# Eventhouse MCP (KQL / telemetry query layer)
EVENTHOUSE_MCP_ENDPOINT=

# Azure Event Grid MQTT broker (device command dispatch)
# Hostname format: <namespace>.<region>-1.ts.eventgrid.azure.net
EVENTGRID_MQTT_HOSTNAME=
EVENTGRID_MQTT_PORT=8883

# Redis cache
REDIS_URL=redis://localhost:6379

# Optional: comma-separated Azure subscription IDs
AZURE_SUBSCRIPTION_IDS=

# Application tuning
STATE_CACHE_TTL_SECONDS=15
