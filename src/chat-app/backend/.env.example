# API settings
# Port used when running uvicorn locally: uvicorn main:app --host 0.0.0.0 --port ${PORT:-5000}
PORT=5000

# Azure Entra ID (Azure AD) App Registration
# Required: Your Azure AD tenant ID (or "common" for multi-tenant)
AZURE_TENANT_ID=
# Required: The Application (client) ID from your App Registration
AZURE_CLIENT_ID=

# Azure Event Grid MQTT endpoint
# Example: <namespace>.<region>-1.ts.eventgrid.azure.net
AZURE_EVENTGRID_MQTT_HOST=
AZURE_EVENTGRID_MQTT_PORT=8883

# Optional MQTT client identity. If empty, a random client ID is generated.
AZURE_EVENTGRID_MQTT_CLIENT_ID=

# MQTT QoS: 0, 1, or 2
MQTT_QOS=1

# Microsoft Fabric Eventhouse status query settings
# Example endpoint: https://<eventhouse>.<region>.kusto.windows.net
FABRIC_EVENTHOUSE_QUERY_URI=
FABRIC_EVENTHOUSE_DATABASE=
# Status lookup uses KQL function: get_beckhoff_last_status(device_name)

# Optional: retries for transient Eventhouse TLS/network failures (default: 5)
FABRIC_EVENTHOUSE_QUERY_RETRIES=5

# Azure Subscription ID — used for Arc status queries against Azure Resource Manager
AZURE_SUBSCRIPTION_ID=

# Optional: Application Insights connection string for telemetry
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Enable Swagger UI and ReDoc at /docs, /redoc, and /openapi.json
# Set to true for local development; leave false (default) in production
ENABLE_DOCS=true

# CORS allowed origins (comma-separated). Set for local development when running
# the frontend and backend on different ports.
# Example: http://localhost:3000,http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:3000
