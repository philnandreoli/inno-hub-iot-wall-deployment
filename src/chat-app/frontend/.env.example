# Azure Entra ID (Azure AD) App Registration
# Required: The Application (client) ID from your App Registration
VITE_AZURE_CLIENT_ID=

# Required: Your Azure AD tenant ID (or "common" for multi-tenant)
VITE_AZURE_TENANT_ID=

# Optional: The API scope exposed by your App Registration
# e.g. api://<client-id>/access_as_user
VITE_AZURE_API_SCOPE=
