{
  "name": "IoT Chat App Dev",

  // Docker Compose brings up the app container (universal image) alongside a
  // Redis 7 sidecar.  Works identically in VS Code local Dev Containers and
  // GitHub Codespaces.
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",
  "shutdownAction": "stopCompose",

  "forwardPorts": [3000, 5000, 6379, 8888],
  "portsAttributes": {
    "3000": { "label": "Frontend (Vite)", "onAutoForward": "notify" },
    "5000": { "label": "Backend (FastAPI)", "onAutoForward": "notify" },
    "6379": { "label": "Redis", "onAutoForward": "silent" },
    "8888": { "label": "Jupyter / misc", "onAutoForward": "silent" }
  },

  // Install Python and Node dependencies after the container is created.
  // The script also writes src/chat-app/backend/.env from any env vars that are
  // already set (Codespaces secrets or locally forwarded remoteEnv values).
  "postCreateCommand": "bash /workspace/.devcontainer/post-create.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylance",
        "ms-python.black-formatter",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-vscode.azure-account",
        "ms-azuretools.vscode-azurefunctions",
        "GitHub.codespaces"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "[python]": {
          "editor.defaultFormatter": "ms-python.black-formatter"
        }
      }
    }
  },

  // -----------------------------------------------------------------------
  // Environment variables
  //
  // LOCAL VS CODE DEV CONTAINERS
  //   Set these variables in your host shell (e.g., ~/.bashrc / ~/.zshrc)
  //   before opening the project in VS Code.  ${localEnv:VAR} reads from
  //   the host environment and forwards the value into the container.
  //
  // GITHUB CODESPACES
  //   Add the same variable names as Codespaces secrets at:
  //     https://github.com/settings/codespaces  (user-level)
  //   or via the repository's Settings → Secrets → Codespaces (repo-level).
  //   Codespaces secrets are injected directly into the container environment
  //   so ${localEnv:VAR} resolves them transparently — no extra steps needed.
  // -----------------------------------------------------------------------
  "remoteEnv": {
    "AZURE_OPENAI_ENDPOINT":    "${localEnv:AZURE_OPENAI_ENDPOINT}",
    "AZURE_OPENAI_DEPLOYMENT":  "${localEnv:AZURE_OPENAI_DEPLOYMENT}",
    "EVENTHOUSE_MCP_ENDPOINT":  "${localEnv:EVENTHOUSE_MCP_ENDPOINT}",
    "EVENTGRID_MQTT_HOSTNAME":  "${localEnv:EVENTGRID_MQTT_HOSTNAME}",
    "EVENTGRID_MQTT_PORT":      "${localEnv:EVENTGRID_MQTT_PORT}",
    "AZURE_SUBSCRIPTION_IDS":   "${localEnv:AZURE_SUBSCRIPTION_IDS}"
  }
}
